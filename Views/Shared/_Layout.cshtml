@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ActiveZone</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold text-success" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-lightning-charge-fill me-1"></i>ActiveZone
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
               <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
    <ul class="navbar-nav flex-grow-1">
        <li class="nav-item">
            <a class="nav-link text-light fw-medium" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-house-door me-1"></i>Ana Vitrin
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-light fw-medium" asp-area="" asp-controller="Announcements" asp-action="Index">
                <i class="bi bi-megaphone me-1"></i>Duyurular
            </a>
        </li>
    </ul>

    <ul class="navbar-nav ms-auto gap-2 align-items-center">
        @if (HttpContextAccessor.HttpContext?.Session?.GetString("IsAdmin") == "true")
        {
            <li class="nav-item">
                <a class="btn btn-outline-warning btn-sm fw-bold px-3 text-white" asp-area="" asp-controller="Announcements" asp-action="Manage">
                    <i class="bi bi-megaphone-fill me-1"></i>Duyuru Paneli
                </a>
            </li>
            <li class="nav-item">
                <a class="btn btn-outline-success btn-sm fw-bold px-3 text-white" asp-area="" asp-controller="Enrollments" asp-action="Index">
                    <i class="bi bi-clipboard-data me-1"></i>Kayıt Takip Paneli
                </a>
            </li>
            <li class="nav-item">
                <a class="btn btn-outline-warning btn-sm fw-bold px-3 text-dark bg-warning" asp-area="" asp-controller="SportCourses" asp-action="Index">
                    <i class="bi bi-sliders me-1"></i>Kurs Tanımlama
                </a>
            </li>
            <li class="nav-item">
                <a class="btn btn-danger btn-sm fw-bold px-3 text-white" asp-area="" asp-controller="Account" asp-action="Logout">
                    <i class="bi bi-box-arrow-right me-1"></i>Çıkış Yap
                </a>
            </li>
        }
        else
        {
            <li class="nav-item">
                <a class="btn btn-outline-light btn-sm fw-bold px-3 text-white" asp-area="" asp-controller="Account" asp-action="Login">
                    <i class="bi bi-person-lock me-1"></i>Yönetici Girişi
                </a>
            </li>
        }
    </ul>
</div>
            </div>
        </nav>
    </header>

    <div class="container px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light mt-5 py-3">
        <div class="container text-center">
            &copy; 2026 - ActiveZone Spor Kursu Kayıt Otomasyonu - <span class="text-secondary fw-semibold">Web Programlama Dersi Dönem Projesi</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>