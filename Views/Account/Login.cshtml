@{
    ViewData["Title"] = "Yönetici Girişi";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-dark text-white text-center py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-lock-fill text-success me-2"></i>ActiveZone Panel</h4>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2 fw-bold text-center">@ViewBag.Error</div>
                }

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-secondary">Kullanıcı Adı</label>
                        <input type="text" name="username" class="form-control" placeholder="admin" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-secondary">Şifre</label>
                        <input type="password" name="password" class="form-control" placeholder="••••" required />
                    </div>

                    <button type="submit" class="btn btn-success w-100 fw-bold py-2 mt-2 shadow-sm">Giriş Yap</button>
                </form>
            </div>
        </div>
    </div>
</div>