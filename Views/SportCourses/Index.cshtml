@model IEnumerable<SportCourseRegistrationSystem.Models.SportCourse>

@{
    ViewData["Title"] = "ActiveZone - Kurs Tanımlama Paneli";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <div>
        <h2 class="text-success fw-bold"><i class="bi bi-trophy me-2"></i>Aktif Spor Kursları</h2>
        <p class="text-muted mb-0">ActiveZone bünyesinde açılan güncel branşlar ve eğitmen kadrosu.</p>
    </div>
    <a asp-action="Create" class="btn btn-success fw-bold py-2 px-3 shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Yeni Kurs Tanımla
    </a>
</div>

<div class="card shadow border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">⚡ Kurs Branşı</th>
                        <th>🪪 Eğitmen</th>
                        <th>👥 Kontenjan</th>
                        <th>⏳ Kurs Süresi (Hafta)</th>
                        <th class="text-center" style="width: 180px;">⚙️ İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark ps-4">@item.CourseName</td>
                            <td class="text-secondary">@item.InstructorName</td>
                            <td>
                                <span class="badge bg-info text-dark fw-bold px-3">@item.Capacity Kişi</span>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border fw-bold">@item.DurationWeeks Hafta</span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm fw-bold">
                                        <i class="bi bi-pencil-square"></i> Düzenle
                                    </a>

                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('@item.CourseName kursunu sistemden tamamen silmek istediğinize emin misiniz? (Bu kursa ait tüm üye kayıtları da silinecektir!)');" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm fw-bold">
                                            <i class="bi bi-trash3-fill"></i> Sil
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>