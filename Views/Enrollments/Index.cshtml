@model IEnumerable<SportCourseRegistrationSystem.Models.Enrollment>

@{
    ViewData["Title"] = "ActiveZone - Kurs Kayıt Takip Paneli";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <div>
        <h2 class="text-success fw-bold">Kurs Kayıt Takip Otomasyonu</h2>
        <p class="text-muted mb-0">Hangi üyenin hangi spor branşına, ne zaman kayıt olduğunu anlık olarak izleyin.</p>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary fw-bold">
        Müşteri Vitrinine Git
    </a>
</div>

<div class="card shadow border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Üye Kodu</th>
                        <th>Adı Soyadı</th>
                        <th>Kayıt Olduğu Branş</th>
                        <th>Kurs Sorumlu Eğitmeni</th>
                        <th>Kayıt Tarihi</th>
                        <th class="text-center">Üye Bilgisi</th>
                        <th class="text-center">Yönetimsel İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                Sistemde henüz gerçekleşmiş bir kurs kaydı bulunmamaktadır.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-primary ps-4">
                                    @(item.Member?.MemberNumber ?? "Sistem Üretimi")
                                </td>
                                <td class="fw-semibold text-dark">
                                    @(item.Member?.FullName ?? "Bilinmeyen Üye")
                                </td>
                                <td>
                                    <span class="badge bg-info text-dark fw-bold">
                                        @(item.SportCourse?.CourseName ?? "Silinmiş Kurs")
                                    </span>
                                </td>
                                <td>
                                    @(item.SportCourse?.InstructorName ?? "-")
                                </td>
                                <td class="text-secondary">
                                    @item.EnrollmentDate.ToString("dd.MM.yyyy HH:mm")
                                </td>
                                
                                <!-- Üye Detayları Modal Butonu -->
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-outline-primary fw-bold" data-bs-toggle="modal" data-bs-target="#modal-@item.Id">
                                        <i class="bi bi-eye-fill me-1"></i> Detaylar
                                    </button>

                                    <!-- Her Üye İçin Dinamik Açılır Pencere (Modal) -->
                                    <div class="modal fade" id="modal-@item.Id" tabindex="-1" aria-labelledby="modalLabel-@item.Id" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content border-0 shadow-lg">
                                                <div class="modal-header bg-dark text-white">
                                                    <h5 class="modal-title fw-bold" id="modalLabel-@item.Id">
                                                        <i class="bi bi-person-vcard text-success me-2"></i>Üye Profil Kartı
                                                    </h5>
                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
                                                </div>
                                                <div class="modal-body p-4 text-start">
                                                    <div class="mb-3">
                                                        <label class="text-muted small d-block">Adı Soyadı</label>
                                                        <span class="fw-bold text-dark fs-5">@(item.Member?.FullName ?? "Bilinmeyen Üye")</span>
                                                    </div>
                                                    <hr class="my-2" />
                                                    <div class="row mb-3">
                                                        <div class="col-6">
                                                            <label class="text-muted small d-block"><i class="bi bi-telephone text-success me-1"></i> Telefon</label>
                                                            <span class="fw-semibold text-dark">@(item.Member?.Phone ?? "-")</span>
                                                        </div>
                                                        <div class="col-6">
                                                            <label class="text-muted small d-block"><i class="bi bi-calendar-event text-primary me-1"></i> Doğum Tarihi</label>
                                                            <span class="fw-semibold text-dark">@(item.Member?.BirthDate.ToString("dd.MM.yyyy") ?? "-")</span>
                                                        </div>
                                                    </div>
                                                    <div class="p-3 bg-light rounded-3 border">
                                                        <label class="text-danger small fw-bold d-block mb-1">
                                                            <i class="bi bi-heart-pulse-fill me-1"></i> Sağlık Durumu / Kronik Rahatsızlık
                                                        </label>
                                                        <span class="fw-bold @(item.Member?.HealthStatus != null && item.Member.HealthStatus.ToLower().Contains("yok") ? "text-success" : "text-danger")">
                                                            @(item.Member?.HealthStatus ?? "Bilgi Girilmemiş")
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="modal-footer bg-light py-2">
                                                    <button type="button" class="btn btn-secondary btn-sm fw-bold" data-bs-dismiss="modal">Kapat</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>

                                <td class="text-center">
                                    <form asp-action="CancelEnrollment" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu kurs kaydını iptal etmek ve kontenjanı iade etmek istediğinize emin misiniz?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm fw-bold">
                                            <i class="bi bi-trash3-fill me-1"></i> Kaydı İptal Et
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>