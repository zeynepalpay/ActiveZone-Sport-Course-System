@{
    ViewData["Title"] = "Kayıt Başarılı";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-7">
        <div class="card shadow border-0 text-center">
            <div class="card-body p-5">
                <div class="mb-4">
                    <span style="font-size: 4rem; color: #198754;">✔</span>
                </div>
                
                <h2 class="text-success fw-bold mb-3">Kayıt başarılı!</h2>
                <p class="text-muted mb-4">Kurs kayıt işleminiz ActiveZone veri tabanına başarıyla işlenmiştir.</p>
                
                <hr />
                
                <h5 class="text-dark fw-bold my-4 text-start">Kayıt ve Üye Bilgileri Özet Dosyası</h5>
                
                <ul class="list-group list-group-flush text-start rounded border">
                    <li class="list-group-item"><strong>Üye Adı Soyadı:</strong> @TempData["MemberName"]</li>
                    <li class="list-group-item"><strong>Üye Numarası:</strong> @TempData["MemberNumber"]</li>
                    <li class="list-group-item"><strong>İletişim Numarası:</strong> @TempData["Phone"]</li>
                    <li class="list-group-item bg-light"><strong>Kayıt Olunan Branş:</strong> <span class="text-primary fw-bold">@TempData["CourseName"]</span></li>
                    <li class="list-group-item bg-light"><strong>Ders Sorumlu Eğitmeni:</strong> @TempData["Instructor"]</li>
                </ul>

                <div class="mt-5">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-5 shadow-sm">Ana Vitrine Dön</a>
                </div>
            </div>
        </div>
    </div>
</div>