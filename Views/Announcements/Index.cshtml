@model IEnumerable<SportCourseRegistrationSystem.Models.Announcement>

@{
    ViewData["Title"] = "Duyurular & Haberler";
}

<div class="my-4 p-4 bg-dark text-white rounded shadow-sm">
    <h1 class="fw-bold text-warning mb-2"><i class="bi bi-megaphone-fill me-2"></i>Duyurular & Önemli Haberler</h1>
    <p class="lead mb-0 opacity-75">Kulübümüz ve aktif eğitim programlarımız hakkındaki en güncel bilgilendirmelere buradan ulaşabilirsiniz.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-9">
        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-light text-center py-5 border shadow-sm rounded-3">
                <i class="bi bi-info-circle display-4 text-secondary d-block mb-2"></i>
                <span class="text-secondary fw-medium">Şu an için yayınlanmış aktif bir duyuru bulunmamaktadır.</span>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                <div class="card mb-4 shadow-sm border-0 border-start border-4 border-warning rounded-3">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h4 class="fw-bold text-dark mb-0">@item.Title</h4>
                            <span class="badge bg-light text-secondary border">
                                <i class="bi bi-calendar3 me-1"></i> @item.Date.ToString("dd MMMM yyyy HH:mm")
                            </span>
                        </div>
                        <p class="text-secondary fs-5 mb-0" style="white-space: pre-line;">@item.Content</p>
                    </div>
                </div>
            }
        }
    </div>
</div>