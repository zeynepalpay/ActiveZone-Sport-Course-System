@model IEnumerable<SportCourseRegistrationSystem.Models.Announcement>

@{
    ViewData["Title"] = "Duyuru Yönetimi";
}

<div class="d-flex justify-content-between align-items-center my-4">
    <h2 class="fw-bold text-dark"><i class="bi bi-gear-fill text-warning me-2"></i>Duyuru Yönetim Paneli</h2>
    <a asp-action="Index" class="btn btn-outline-secondary fw-bold"><i class="bi bi-eye me-1"></i> Canlı Sayfayı Gör</a>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-dark text-white fw-bold py-3">
                <i class="bi bi-plus-circle-fill text-success me-2"></i>Yeni Duyuru Yayınla
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-secondary">Duyuru Başlığı</label>
                        <input type="text" name="title" class="form-control" placeholder="Örn: Bayram Tatili Hakkında" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-secondary">Duyuru İçeriği</label>
                        <textarea name="content" class="form-control" rows="5" placeholder="Duyuru metnini buraya yazın..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-warning w-100 fw-bold py-2 shadow-sm"><i class="bi bi-send-fill me-1"></i> Yayınla</button>
                </form>
            </div>
        </div>
        
        @if (Model != null && Model.Any())
        {
            <form asp-action="DeleteAll" method="post" class="mt-3" onsubmit="return confirm('Tüm duyuruları tamamen silmek istediğinize emin misiniz?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger w-100 btn-sm fw-bold"><i class="bi bi-trash3 me-1"></i> Tüm Duyuruları Temizle</button>
            </form>
        }
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-secondary text-white fw-bold py-3">
                <i class="bi bi-list-ul me-2"></i>Sistemde Kayıtlı Duyurular (@Model?.Count())
            </div>
            <div class="card-body p-0">
                @if (Model == null || !Model.Any())
                {
                    <div class="text-center p-5 text-muted">Henüz hiçbir duyuru eklenmemiş.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 20%">Tarih</th>
                                    <th style="width: 25%">Başlık</th>
                                    <th>İçerik Özeti</th>
                                    <th style="width: 15%" class="text-center">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="small text-secondary">@item.Date.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td class="fw-bold text-dark">@item.Title</td>
                                        <td class="text-muted text-truncate" style="max-width: 250px;">@(item.Content ?? "")</td>
                                        <td class="text-center">
                                            <form asp-action="DeleteAnnouncement" asp-route-title="@item.Title" method="post" onsubmit="return confirm('Bu duyuruyu silmek istediğinize emin misiniz?');" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger fw-bold">
                                                    <i class="bi bi-trash"></i> Sil
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>